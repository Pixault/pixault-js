{
  "name": "@pixault/sdk",
  "version": "1.1.0",
  "description": "Official JavaScript/TypeScript SDK for the Pixault image CDN",
  "author": "Endpoint Systems",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "tsup": "^8.0.0",
    "typescript": "^5.7.0"
  },
  "keywords": [
    "pixault",
    "image",
    "cdn",
    "upload",
    "resize",
    "transform",
    "optimization"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/Pixault/pixault-js"
  },
  "engines": {
    "node": ">=18"
  }
}
